# ============================================================
# Arquivo de exemplo (.env) — Atribuição de Tickets
# Copie este arquivo para ".env" e preencha os valores.
# ============================================================

# ---------------------------
# NestJS Backend
# ---------------------------
PORT=3001
# Chave secreta para sessões. Gere um valor forte antes de rodar fora do dev:
# openssl rand -base64 48
SESSION_SECRET=
# URL de conexão do PostgreSQL.
# Em Docker Compose, o serviço app sobrescreve para usar o host "postgres".
DATABASE_URL=postgres://assignment_tickets:assignment_tickets@localhost:5432/assignment_tickets
DATABASE_POOL_MAX=10
# Use true se o Postgres gerenciado exigir TLS.
DATABASE_SSL=false

# ---------------------------
# API Movidesk — Tickets
# ---------------------------
MOVIDESK_API_URL=https://api.movidesk.com/public/v1/tickets
MOVIDESK_API_TOKEN=
MOVIDESK_API_TIMEOUT=10000
# Querystring de busca de tickets (ajuste o filtro de equipe)
MOVIDESK_API_QUERY_PARAMS='$select=id,subject,status,owner,ownerTeam,slaSolutionDate,slaSolutionDateIsPaused,createdDate,lastUpdate,serviceFirstLevel,serviceFull,category,urgency&$filter=ownerTeam eq %27Minha Equipe%27&$orderby=id desc&$top=300&$skip=0&$expand=owner'
MOVIDESK_DEBUG_DATE_FIELDS=false
MOVIDESK_DEBUG_DATE_FIELDS_SAMPLE_SIZE=5
MOVIDESK_SYNC_MIN_INTERVAL_SECONDS=25

# ---------------------------
# MCP Movidesk — Agente IA
# ---------------------------
# Servidor MCP: https://lobehub.com/mcp/raylann-lopes-mcp-movidesk
# Em Docker, o servidor MCP já vai empacotado em /app/mcp-movidesk.
# Deixe vazio para o backend reutilizar MOVIDESK_API_TOKEN.
MOVIDESK_TOKEN=

# ---------------------------
# API Movidesk — Pessoas/Agentes
# ---------------------------
MOVIDESK_PERSONS_API_URL=https://api.movidesk.com/public/v1/persons
MOVIDESK_PERSONS_QUERY_PARAMS='$select=businessName,profileType,isActive,teams&$top=200'
MOVIDESK_PERSONS_PAGE_SIZE=200
MOVIDESK_PERSONS_MAX_PAGES=10
# Cache de agentes em segundos
MOVIDESK_PERSONS_CACHE_SECONDS=300
# Nomes das equipes permitidas no seletor de atribuição
ASSIGNMENT_TEAM_NAMES=Minha Equipe

# ---------------------------
# Email (SMTP)
# ---------------------------
MAIL_HOST=smtp.exemplo.com
MAIL_PORT=587
MAIL_USER=no-reply@exemplo.com
MAIL_PASS=
MAIL_FROM="Atribuição de Tickets <no-reply@exemplo.com>"
# URL base para links nos e-mails de recuperação de senha
# Em produção: URL pública do frontend (ex.: https://meu-app.vercel.app)
APP_BASE_URL=http://localhost:5173

# URL do backend em produção (usada pelo frontend na Vercel)
# Em desenvolvimento deixe vazio — o proxy do Vite cobre isso
VITE_API_BASE_URL=

# Base da instância do Movidesk usada para abrir links de chamados
VITE_MOVIDESK_BASE_URL=https://atendimento.nappsolutions.com

# ---------------------------
# Google OAuth — Login corporativo
# ---------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL pública do callback no backend. Ex.: https://seu-dominio.com/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback
# Bloqueia login fora do domínio corporativo. Ex.: nappsolutions.com
GOOGLE_ALLOWED_DOMAIN=nappsolutions.com

# ---------------------------
# Trello
# ---------------------------
TRELLO_API_KEY=
TRELLO_API_TOKEN=
TRELLO_API_TIMEOUT=10000
TRELLO_DEFAULT_BOARD_ID=
TRELLO_DEFAULT_LIST_ID=
MOVIDESK_ATTACHMENT_URL_TEMPLATE=
