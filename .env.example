# ============================================================
# Arquivo de exemplo (.env) — Atribuição de Tickets
# Copie este arquivo para ".env" e preencha os valores.
# ============================================================

# ---------------------------
# NestJS Backend
# ---------------------------
PORT=3001
# Chave secreta para sessões (use valor forte em produção)
SESSION_SECRET=changeme-super-secret-key
# Caminho para o banco de dados SQLite.
# Use um diretório persistente em produção para não perder dados nos deploys.
DATABASE_PATH=./data/tickets.db
# Diretório persistente opcional. Em containers/volumes, prefira /data.
PERSISTENT_DATA_DIR=

# ---------------------------
# API Movidesk — Tickets
# ---------------------------
MOVIDESK_API_URL=https://api.movidesk.com/public/v1/tickets
MOVIDESK_API_TOKEN=47d287de-0026-4abb-ae48-643d18aed272
# Modo de autenticação: query | bearer
MOVIDESK_API_AUTH_MODE=query
MOVIDESK_API_TIMEOUT=10000
# Querystring de busca de tickets (ajuste o filtro de equipe)
MOVIDESK_API_QUERY_PARAMS=$select=id,subject,status,owner,ownerTeam,slaSolutionDate,slaSolutionDateIsPaused,createdDate,lastUpdate,serviceFirstLevel,serviceFull,category,urgency&$filter=ownerTeam eq 'Minha Equipe'&$orderby=id desc&$top=300&$skip=0&$expand=owner
MOVIDESK_DEBUG_DATE_FIELDS=false
MOVIDESK_DEBUG_DATE_FIELDS_SAMPLE_SIZE=5
MOVIDESK_TICKETS_MAX_PAGES=10
MOVIDESK_SYNC_MIN_INTERVAL_SECONDS=25

# ---------------------------
# MCP Movidesk — Agente IA
# ---------------------------
# Servidor MCP: https://lobehub.com/mcp/raylann-lopes-mcp-movidesk
# Clone/instale o servidor MCP fora deste app, compile com npm run build,
# e aponte para o dist/index.js dele.
MOVIDESK_MCP_COMMAND=node
MOVIDESK_MCP_ARGS=["/media/kauetorres/Novo volume/MCPMovidesk/MCP_EAGLE/dist/index.js"]
MOVIDESK_MCP_CWD=/media/kauetorres/Novo volume/MCPMovidesk/MCP_EAGLE
# Se vazio, o backend usa MOVIDESK_API_TOKEN como MOVIDESK_TOKEN para o MCP.
MOVIDESK_TOKEN=47d287de-0026-4abb-ae48-643d18aed272

# ---------------------------
# API Movidesk — Pessoas/Agentes
# ---------------------------
MOVIDESK_PERSONS_API_URL=https://api.movidesk.com/public/v1/persons
MOVIDESK_PERSONS_QUERY_PARAMS=$select=businessName,profileType,isActive,teams&$top=200
MOVIDESK_PERSONS_PAGE_SIZE=200
MOVIDESK_PERSONS_MAX_PAGES=10
# Cache de agentes em segundos
MOVIDESK_PERSONS_CACHE_SECONDS=300
# Query para fallback de responsáveis a partir dos tickets
MOVIDESK_ASSIGNMENT_TICKETS_QUERY_PARAMS=$select=id,owner,ownerTeam,status&$filter=ownerTeam eq 'Minha Equipe'&$orderby=id desc&$top=500&$skip=0&$expand=owner
# Nomes das equipes permitidas no seletor de atribuição
ASSIGNMENT_TEAM_NAMES=Minha Equipe

# ---------------------------
# Email (SMTP)
# ---------------------------
MAIL_SERVER=smtp.exemplo.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=no-reply@exemplo.com
MAIL_PASSWORD=
MAIL_FROM="Atribuição de Tickets <no-reply@exemplo.com>"
# URL base para links nos e-mails de recuperação de senha
# Em produção: URL pública do frontend (ex.: https://meu-app.vercel.app)
APP_BASE_URL=http://localhost:5173

# URL do backend em produção (usada pelo frontend na Vercel)
# Em desenvolvimento deixe vazio — o proxy do Vite cobre isso
VITE_API_BASE_URL=

# Base da instância do Movidesk usada para abrir links de chamados
VITE_MOVIDESK_BASE_URL=https://atendimento.nappsolutions.com
